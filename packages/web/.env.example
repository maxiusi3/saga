# Saga web local environment example
# Copy to packages/web/.env.local for local development.
# Never commit real values.

# App URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_ENV=development

# Supabase
# Use values from Supabase Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY

# AI services
OPENROUTER_API_KEY=OPENROUTER_API_KEY
NEXT_PUBLIC_OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
SILICONFLOW_API_KEY=REPLACE_WITH_SILICONFLOW_KEY
SILICONFLOW_MODEL=FunAudioLLM/SenseVoiceSmall

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY

# Scheduled admin routes
ADMIN_CRON_SECRET=REPLACE_WITH_RANDOM_CRON_SECRET

# Optional integrations
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
