# Saga production environment example
# Configure these in Vercel Project Settings > Environment Variables.
# Never commit real values.

# Public app URLs
NEXT_PUBLIC_WEB_URL=https://app.example.com
NEXT_PUBLIC_SITE_URL=https://app.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://app.example.com/api
NEXT_PUBLIC_ENV=production

# Supabase
# Public values are safe for the browser; service role remains server-only.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY

# AI services
# OpenRouter keys start with sk-or-v1-.
OPENROUTER_API_KEY=OPENROUTER_API_KEY
NEXT_PUBLIC_OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
SILICONFLOW_API_KEY=SILICONFLOW_API_KEY
SILICONFLOW_MODEL=FunAudioLLM/SenseVoiceSmall

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY

# Scheduled admin routes
ADMIN_CRON_SECRET=ADMIN_CRON_SECRET

# OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID

# Observability
NEXT_PUBLIC_ANALYTICS_ID=ANALYTICS_ID
NEXT_PUBLIC_SENTRY_DSN=SENTRY_PUBLIC_DSN
SENTRY_DSN=SENTRY_SERVER_DSN
